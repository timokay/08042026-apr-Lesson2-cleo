# ============================================================
# Клёво — Environment Variables Template
# Copy to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# ------------------------------------------------------------
# Supabase (self-hosted on VPS)
# ------------------------------------------------------------
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
JWT_SECRET=your-super-secret-jwt-secret-min-32-chars

# ------------------------------------------------------------
# AI APIs
# ------------------------------------------------------------
# Claude via proxyapi.ru (required for access from Russia)
CLAUDE_API_KEY=sk-ant-your-key-here
PROXY_API_URL=https://api.proxyapi.ru/anthropic

# YandexGPT (fallback, direct access from RU VPS)
YANDEX_GPT_API_KEY=your-yandexgpt-api-key
YANDEX_GPT_FOLDER_ID=your-yandex-cloud-folder-id

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
POSTGRES_PASSWORD=your-strong-postgres-password

# ------------------------------------------------------------
# Payments (Robokassa)
# ------------------------------------------------------------
ROBOKASSA_MERCHANT_LOGIN=your-merchant-login
ROBOKASSA_PASSWORD1=your-password1-for-payment-links
ROBOKASSA_PASSWORD2=your-password2-for-webhook-verification
ROBOKASSA_TEST_MODE=true

# ------------------------------------------------------------
# Telegram alerting (optional — for ops notifications)
# ------------------------------------------------------------
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_ALERT_CHAT_ID=your-chat-id

# Plus plan pricing
PLUS_PRICE_RUB=299.00
PLUS_DURATION_DAYS=30

# ------------------------------------------------------------
# App URLs
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=https://klevo.app
# Development: http://localhost:3000
